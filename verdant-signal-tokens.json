  "$themes": [
    {
      "name": "Dark",
      "group": "Mode",
      "selectedTokenSets": {
        "Global": "enabled",
        "Mode/Dark": "enabled",
        "Mode/Light": "disabled"
      }
    },
    {
      "name": "Light",
      "group": "Mode",
      "selectedTokenSets": {
        "Global": "enabled",
        "Mode/Dark": "disabled",
        "Mode/Light": "enabled"
      }
    }
  ],
  "$metadata": {
    "tokenSetOrder": ["Global", "Mode/Dark", "Mode/Light"]
  }
