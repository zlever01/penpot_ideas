{
  "Global": {
    "radius": {
      "card": { "$value": 14, "$type": "borderRadius", "$description": "Cards, primary content containers" },
      "button": { "$value": 10, "$type": "borderRadius", "$description": "Buttons, slightly tighter than cards" },
      "input": { "$value": 9, "$type": "borderRadius", "$description": "Inputs, dropdowns, nav items" },
      "pill": { "$value": 20, "$type": "borderRadius", "$description": "Badges, pills, time period selectors — full pill shape" },
      "swatch": { "$value": 8, "$type": "borderRadius", "$description": "Small decorative elements, icon containers" }
    },
    "spacing": {
      "2xs": { "$value": 2, "$type": "spacing", "$description": "Inline gaps — badge padding, icon margins" },
      "xs": { "$value": 4, "$type": "spacing", "$description": "Tight grouping — chip sets, stat change row" },
      "sm": { "$value": 6, "$type": "spacing", "$description": "Button gaps, element spacing" },
      "md": { "$value": 8, "$type": "spacing", "$description": "Card grid gaps, section spacing" },
      "lg": { "$value": 12, "$type": "spacing", "$description": "Card internal padding, sidebar sections" },
      "xl": { "$value": 14, "$type": "spacing", "$description": "Card padding (sides)" },
      "2xl": { "$value": 16, "$type": "spacing", "$description": "Card padding (vertical), main regions" },
      "3xl": { "$value": 20, "$type": "spacing", "$description": "Page gutter, section separation" },
      "4xl": { "$value": 24, "$type": "spacing", "$description": "Main content padding" }
    },
    "sizing": {
      "sidebar-width": { "$value": 240, "$type": "sizing", "$description": "Sidebar fixed width" },
      "avatar": { "$value": 32, "$type": "sizing", "$description": "User avatar in sidebar profile" },
      "icon-sm": { "$value": 13, "$type": "sizing", "$description": "Small inline icons — button icons, status indicators" },
      "icon-md": { "$value": 16, "$type": "sizing", "$description": "Standard icons — navigation, toolbar" },
      "slider-track": { "$value": 5, "$type": "sizing", "$description": "Slider and progress bar track height" },
      "slider-thumb": { "$value": 14, "$type": "sizing", "$description": "Slider thumb diameter" },
      "nav-accent-bar": { "$value": 3, "$type": "sizing", "$description": "Active nav item left accent bar width" },
      "dot-indicator": { "$value": 6, "$type": "sizing", "$description": "Activity feed dot indicators" },
      "pulse-dot": { "$value": 8, "$type": "sizing", "$description": "Animated live status pulse dot" }
    },
    "strokeWidth": {
      "border": { "$value": 1, "$type": "strokeWidth", "$description": "Standard border width" },
      "table-hover": { "$value": 2, "$type": "strokeWidth", "$description": "Table row hover left-border accent" },
      "nav-accent": { "$value": 3, "$type": "strokeWidth", "$description": "Active navigation left accent bar" },
      "slider-thumb-ring": { "$value": 2.5, "$type": "strokeWidth", "$description": "Slider thumb border ring" }
    },
    "opacity": {
      "noise-dark": { "$value": "2.5%", "$type": "opacity", "$description": "Noise texture overlay — dark mode" },
      "noise-light": { "$value": "1.5%", "$type": "opacity", "$description": "Noise texture overlay — light mode" },
      "disabled": { "$value": "45%", "$type": "opacity", "$description": "Disabled state for interactive elements" }
    },
    "fontFamily": {
      "display": { "$value": "DM Sans, system-ui, sans-serif", "$type": "fontFamily", "$description": "Primary UI font — headings, labels, body, buttons, navigation" },
      "mono": { "$value": "JetBrains Mono, monospace", "$type": "fontFamily", "$description": "Data font — stat values, timestamps, section headers, badges, code" }
    },
    "fontSize": {
      "stat-value": { "$value": 22, "$type": "fontSize", "$description": "Large stat card numbers" },
      "page-title": { "$value": 20, "$type": "fontSize", "$description": "Main page heading" },
      "card-title": { "$value": 13, "$type": "fontSize", "$description": "Card section headings" },
      "nav-item": { "$value": 12.5, "$type": "fontSize", "$description": "Sidebar navigation items" },
      "button-md": { "$value": 12, "$type": "fontSize", "$description": "Default button text" },
      "button-sm": { "$value": 11, "$type": "fontSize", "$description": "Small button text" },
      "button-lg": { "$value": 13, "$type": "fontSize", "$description": "Large button text" },
      "body": { "$value": 11, "$type": "fontSize", "$description": "Body text, descriptions" },
      "label": { "$value": 10, "$type": "fontSize", "$description": "Dropdown labels, stat labels, meta text" },
      "section-header": { "$value": 9, "$type": "fontSize", "$description": "Sidebar section headers — uppercase monospace" },
      "badge": { "$value": 9, "$type": "fontSize", "$description": "Badge and pill text" },
      "caption": { "$value": 9, "$type": "fontSize", "$description": "Chart axis labels, timestamps" }
    },
    "fontWeight": {
      "black": { "$value": 800, "$type": "fontWeight", "$description": "Page titles, stat values, logo" },
      "bold": { "$value": 700, "$type": "fontWeight", "$description": "Card titles, section headers, badges" },
      "semibold": { "$value": 600, "$type": "fontWeight", "$description": "Buttons, active nav, emphasis" },
      "medium": { "$value": 500, "$type": "fontWeight", "$description": "Labels, chart legends" },
      "regular": { "$value": 450, "$type": "fontWeight", "$description": "Inactive nav items, table body" },
      "normal": { "$value": 400, "$type": "fontWeight", "$description": "Body text, dropdown options" }
    },
    "letterSpacing": {
      "tight": { "$value": -0.5, "$type": "letterSpacing", "$description": "Page titles, stat values" },
      "normal": { "$value": 0, "$type": "letterSpacing", "$description": "Body text, buttons, nav" },
      "wide": { "$value": 0.5, "$type": "letterSpacing", "$description": "Uppercase labels" },
      "wider": { "$value": 1, "$type": "letterSpacing", "$description": "Section headers — FILTERS, MODEL PARAMETERS" }
    },
    "typography": {
      "stat-value": {
        "$value": { "fontFamily": "{fontFamily.mono}", "fontSize": "{fontSize.stat-value}", "fontWeight": "{fontWeight.black}", "letterSpacing": "{letterSpacing.tight}", "lineHeight": 1 },
        "$type": "typography", "$description": "Large metric numbers — $48.2K, 2,847, 32.4%"
      },
      "page-title": {
        "$value": { "fontFamily": "{fontFamily.display}", "fontSize": "{fontSize.page-title}", "fontWeight": "{fontWeight.black}", "letterSpacing": "{letterSpacing.tight}", "lineHeight": 1.2 },
        "$type": "typography", "$description": "Main page heading"
      },
      "card-title": {
        "$value": { "fontFamily": "{fontFamily.display}", "fontSize": "{fontSize.card-title}", "fontWeight": "{fontWeight.bold}", "letterSpacing": "{letterSpacing.normal}", "lineHeight": 1.3 },
        "$type": "typography", "$description": "Card section headings"
      },
      "button": {
        "$value": { "fontFamily": "{fontFamily.display}", "fontSize": "{fontSize.button-md}", "fontWeight": "{fontWeight.semibold}", "letterSpacing": "{letterSpacing.normal}", "lineHeight": 1 },
        "$type": "typography", "$description": "Default button label"
      },
      "body": {
        "$value": { "fontFamily": "{fontFamily.display}", "fontSize": "{fontSize.body}", "fontWeight": "{fontWeight.medium}", "letterSpacing": "{letterSpacing.normal}", "lineHeight": 1.6 },
        "$type": "typography", "$description": "Body text, descriptions"
      },
      "section-header": {
        "$value": { "fontFamily": "{fontFamily.mono}", "fontSize": "{fontSize.section-header}", "fontWeight": "{fontWeight.bold}", "letterSpacing": "{letterSpacing.wider}", "lineHeight": 1.3, "textCase": "uppercase" },
        "$type": "typography", "$description": "Sidebar section headers — FILTERS, MODEL PARAMETERS"
      },
      "badge": {
        "$value": { "fontFamily": "{fontFamily.mono}", "fontSize": "{fontSize.badge}", "fontWeight": "{fontWeight.bold}", "letterSpacing": "{letterSpacing.normal}", "lineHeight": 1.2 },
        "$type": "typography", "$description": "Badge and pill text"
      }
    }
  },
