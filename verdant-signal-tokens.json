          { "color": "rgba(0, 0, 0, 0.25)", "offsetX": 0, "offsetY": 8, "blur": 24, "spread": 0, "type": "dropShadow" },
          { "color": "rgba(255, 255, 255, 0.03)", "offsetX": 0, "offsetY": 1, "blur": 0, "spread": 0, "type": "innerShadow" }
